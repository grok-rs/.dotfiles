#!/usr/bin/env bash
set -euo pipefail

DOTFILES="$(cd "$(dirname "$0")" && pwd)"
STOW_FOLDERS="bin,nvim,personal,tmux,zsh,sway,waybar,zed,neovide"

cd "$DOTFILES"

# Initialize submodules
git submodule update --init --recursive

# Stow each package
for folder in $(echo "$STOW_FOLDERS" | tr ',' ' '); do
    if [[ -d "$folder" ]]; then
        echo "Linking $folder..."
        stow -D "$folder" 2>/dev/null || true
        stow "$folder"
    fi
done

echo "Done! Restart your shell or run: exec zsh"
